        [
          {
            "node": "📥 Get Next Approved Post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "📥 Get Next Approved Post": {
      "main": [
        [
          {
            "node": "🔀 Has Row?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "🔀 Has Row?": {
      "main": [
        [
          {
            "node": "⚙️ Extract Post Data",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "⚙️ Extract Post Data": {
      "main": [
        [
          {
            "node": "🚦 Mark Publishing",
            "type": "main",
