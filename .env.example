# ─── Cosmic Pet Portraits — environment variables ─────────────────────────
# Set these in Vercel (Project → Settings → Environment Variables) and locally
# in .env. NEVER commit a real .env to git.
#
# Most of the existing env is already configured in Vercel; this file is the
# canonical reference of what each handler needs. The ⭐ markers call out the
# ones added/required for the Phase 9 Gelato fulfillment + print quality work
# (2026-05-08).

# ─── Supabase ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://aduibsyrnenzobuyetmn.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Shopify ───────────────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_SHOP_DOMAIN=

# ─── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── fal.ai (preview generation + AuraSR upscale) ──────────────────────────
FAL_KEY=
# Optional: gpt-image-2 base quality for previews (default 'medium').
# DO NOT set to 'high' here — print masters force 'high' regardless via the
# scoped override in handlePrintMaster. Setting it here would raise customer
# preview costs without benefit.
GPT_IMAGE_QUALITY=medium

# ─── Gelato — print fulfillment + inbound webhooks ⭐ ──────────────────────
# Outbound order submission: api/_lib/printPipeline.ts
GELATO_API_KEY=
# Inbound webhook signature verification: api/gelato/webhook.ts
# Source from Gelato dashboard → Webhooks → reveal secret.
GELATO_WEBHOOK_SECRET=

# Feature flag — gate large-format SKUs (long edge >16in) until upscaling has
# been verified end-to-end on production samples. Set to 'true' once
# scripts/test-print-pipeline.ts has cleared 5+ orders at each large size.
LARGE_FORMAT_ENABLED=false
# Optional override — block above this long-edge inch value when the flag is
# false. Default 16 (allows 8x10, 12x16, 12x18, 16x20, but blocks 16x24+).
LARGE_FORMAT_LONG_EDGE_IN=16

# ─── Telegram ops alerts ⭐ ────────────────────────────────────────────────
# Reuses the worker.ts pattern. Hard-coded chat_id is Danny (8006830504, see
# ~/.claude/rules/telegram.md). Provide TOKEN here only — chat_id is in code.
TELEGRAM_BOT_TOKEN=

# ─── Printful (legacy mockup generator) ───────────────────────────────────
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=

# ─── n8n soul-reading webhook ──────────────────────────────────────────────
N8N_SOUL_READING_WEBHOOK_URL=https://n8n.quantumcorehub.net/webhook/generate-report
N8N_BRIDGE_SECRET=

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Admin secrets ─────────────────────────────────────────────────────────
ADMIN_TEST_SECRET=

# ─── OpenRouter / AI ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── UGC Facebook backstory pipeline ⭐ ───────────────────────────────────
# FB Page accountId in Blotato. Resolved by connecting the @littlesoulsapp
# Facebook Page in the Blotato dashboard, then copying the numeric account ID.
# Set in n8n environment (NOT here) so the workflow can pick it up at run time.
FB_PAGE_ACCOUNT_ID=

# Remotion render endpoint for the UGC carousel composer. Set this once
# /render-carousel is deployed; until then the n8n workflow keeps the render
# node disabled and posts the raw photo + canvas via Blotato directly.
REMOTION_RENDER_URL=
