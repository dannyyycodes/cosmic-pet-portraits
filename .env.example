# ────────────────────────────────────────────────────────────────────────────
# Pawtraits — environment variables
# ────────────────────────────────────────────────────────────────────────────
# Local: copy to .env.local; Vercel: set via dashboard (Production + Preview).
# This file is committed; never put real secrets here.

# UGC Facebook backstory pipeline (built 2026-05-08)
# ----------------------------------------------------------------------------
# FB Page accountId in Blotato. Resolved by connecting the @littlesoulsapp
# Facebook Page in the Blotato dashboard, then copying the numeric account ID.
# Set in n8n environment (NOT here) so the workflow can pick it up at run time.
FB_PAGE_ACCOUNT_ID=

# Remotion render endpoint for the UGC carousel composer. Set this once
# /render-carousel is deployed; until then the n8n workflow keeps the render
# node disabled and posts the raw photo + canvas via Blotato directly.
REMOTION_RENDER_URL=

# Gelato webhook — registered in the Gelato dashboard so order-fulfilment
# events can be relayed back into Pawtraits. Owned by Agent A's branch.
GELATO_WEBHOOK_SECRET=
