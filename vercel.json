{
  "functions": {
    "api/cron/*.ts": { "maxDuration": 300 },
    "api/portraits.ts": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-horoscopes",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 10 * * 1,3,5"
    },
    {
      "path": "/api/cron/memorial-touchpoints",
      "schedule": "15 12 * * *"
    },
    {
      "path": "/api/soul-reading?action=reconcile",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron/generation-recovery",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/gelato-worker",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/149e9513-01fa-4fb0-aad4-566afd725d1b/2d206a39-8ed7-437e-a3be-862e0f06eea3/:path*",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/og-image.jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=1800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://browser.sentry-cdn.com https://www.clarity.ms https://connect.facebook.net https://analytics.tiktok.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.supabase.co https://*.stripe.com https://*.wikimedia.org https://images.pexels.com https://www.facebook.com https://analytics.tiktok.com https://images.dog.ceo https://cdn2.thecatapi.com https://fal.media https://*.fal.media; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://nominatim.openstreetmap.org https://www.google-analytics.com https://*.sentry.io https://*.ingest.de.sentry.io https://en.wikipedia.org https://www.clarity.ms https://analytics.tiktok.com https://www.facebook.com https://dog.ceo https://api.thecatapi.com https://open.er-api.com https://fal.run https://*.fal.run https://queue.fal.run; frame-src https://js.stripe.com https://hooks.stripe.com; frame-ancestors 'self'; worker-src 'self' blob:" }
      ]
    }
  ],
  "redirects": [
    { "source": "/portraits", "destination": "/pawtraits", "permanent": true },
    { "source": "/portraits/templates", "destination": "/pawtraits/templates", "permanent": true },
    { "source": "/portraits/studio", "destination": "/pawtraits#studio", "permanent": true },
    { "source": "/pawtrait", "destination": "/pawtraits", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/149e9513-01fa-4fb0-aad4-566afd725d1b/2d206a39-8ed7-437e-a3be-862e0f06eea3/a-4-a/c.js",
      "destination": "https://api.vercel.com/bot-protection/v1/challenge"
    },
    {
      "source": "/149e9513-01fa-4fb0-aad4-566afd725d1b/2d206a39-8ed7-437e-a3be-862e0f06eea3/:path*",
      "destination": "https://api.vercel.com/bot-protection/v1/proxy/:path*"
    },
    { "source": "/apple-touch-icon.png", "destination": "/og-image.jpg" },
    { "source": "/apple-touch-icon-precomposed.png", "destination": "/og-image.jpg" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/reading/:token", "destination": "/api/soul-reading?action=view&token=:token" },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawl|spider|slurp|yandex|baiduspider|anthropic|claudebot|claude-web|gptbot|chatgpt-user|oai-searchbot|perplexity|applebot|amazonbot|meta-external|google-extended|ccbot|duckassistbot|twitterbot|facebookexternalhit|linkedinbot|whatsapp|telegrambot|mj12bot|ahrefsbot|semrushbot|bytespider).*"
        }
      ],
