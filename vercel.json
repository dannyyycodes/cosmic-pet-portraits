{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/checkout-v3", "destination": "/checkout.html" },
    { "source": "/free-chart", "destination": "/free-chart.html" },
    { "source": "/soul-chat", "destination": "/soul-chat.html" },
    { "source": "/gift-v2", "destination": "/gift-v2.html" },
    { "source": "/report-full-v2", "destination": "/report-full-v2.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
