      "has": [
        { "type": "header", "key": "user-agent", "value": "(?i).*(bot|crawl|spider|slurp|yandex|baiduspider|anthropic|claudebot|claude-web|gptbot|chatgpt-user|oai-searchbot|perplexity|applebot|amazonbot|meta-external|google-extended|ccbot|duckassistbot|pinterest|pinterestbot|twitterbot|facebookexternalhit|facebot|linkedinbot|slackbot|whatsapp|telegrambot|discordbot|mj12bot|ahrefsbot|semrushbot|bytespider).*" }
      ],
      "destination": "/api/pawtraits-ssr?path=breed&slug=:slug"
